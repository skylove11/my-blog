---
import BaseLayout from "./BaseLayout.astro";

interface Props {
	frontmatter: {
		title: string;
		description?: string;
	};
}

const { frontmatter } = Astro.props;
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
	<article class="prose">
		<slot />
	</article>
</BaseLayout>
