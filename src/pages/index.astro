---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteDescription } from "../site.config";

const base = import.meta.env.BASE_URL.endsWith("/")
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="My Blog" description={siteDescription}>
	<h1>환영합니다</h1>
	<p class="lead">{siteDescription}</p>
	<p class="muted">
		글 목록은 <a href={`${base}blog`}>Blog</a>, 소개는 <a href={`${base}about`}>About</a>, 새 글 알림은
		<a href={`${base}rss.xml`}>RSS</a>로 구독할 수 있습니다.
	</p>
</BaseLayout>
