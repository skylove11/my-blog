---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getPublishedPosts } from "../../../lib/blog";
const posts = await getPublishedPosts();
const catSet = new Set<string>();
for (const p of posts) {
	for (const c of p.data.categories) {
		catSet.add(c);
	}
}
const categories = [...catSet].sort((a, b) => a.localeCompare(b, "ko"));
const base = import.meta.env.BASE_URL.endsWith("/")
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="카테고리" description="블로그 카테고리 목록">
	<h1>카테고리</h1>
	{
		categories.length === 0 ? (
			<p class="muted">등록된 카테고리가 없습니다.</p>
		) : (
			<ul class="pill-list">
				{categories.map((c) => (
					<li>
						<a href={`${base}blog/categories/${encodeURIComponent(c)}`}>{c}</a>
					</li>
				))}
			</ul>
		)
	}
</BaseLayout>
